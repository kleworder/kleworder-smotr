{
  "version": 2,
  "rewrites": [
    { "source": "/api/media/stats", "destination": "/api/media.js" },
    { "source": "/api/media/:id", "destination": "/api/media.js" },
    { "source": "/api/media", "destination": "/api/media.js" },
    { "source": "/api/search/shikimori/url", "destination": "/api/search.js" },
    { "source": "/api/search/shikimori/:id", "destination": "/api/search.js" },
    { "source": "/api/search/shikimori", "destination": "/api/search.js" },
    { "source": "/api/search/kinopoisk/url", "destination": "/api/search.js" },
    { "source": "/api/search/kinopoisk/:id", "destination": "/api/search.js" },
    { "source": "/api/search/kinopoisk", "destination": "/api/search.js" },
    { "source": "/api/search/omdb/url", "destination": "/api/search.js" },
    { "source": "/api/search/omdb", "destination": "/api/search.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}