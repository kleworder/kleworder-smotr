# Supabase PostgreSQL Connection String
# Получить: https://supabase.com → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres

# OMDB API ключ (опционально)
OMDB_API_KEY=your_omdb_key_here

# poiskkino.dev API ключ (опционально, есть дефолтный)
# POISKKINO_API_KEY=your_key_here
